{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "README.md",
    "ai/AGENTS.md",
    "ai/backend-architecture.md",
    "ai/frontend-architecture.md",
    ".opencode/instruct/build.md"
  ],
  "agent": {
    "tester": {
      "description": "Runs backend tests and reports failures. Use only for Build-mode test verification.",
